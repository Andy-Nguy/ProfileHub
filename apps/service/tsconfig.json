{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../../",
    "module": "CommonJS",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "outDir": "../../dist/apps/service",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "../../libs/shared/data-access/src/**/*.ts",
    "../../libs/shared/types/types.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}