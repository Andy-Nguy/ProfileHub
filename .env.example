# ─── ProfileHub Environment ─────────────────────────────────────────
NODE_ENV=
PORT=

# ─── Database ────────────────────────────────────────────────────────
DB_HOST=
DB_PORT=
DB_USER=
DB_PASS=
DB_NAME=

# ─── JWT Secrets ─────────────────────────────────────────────────────
# IMPORTANT: Generate strong, unique secrets for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-access-token-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=

# ─── Mail ────────────────────────────────────────────────────────────
MAIL_USER=
MAIL_PASS=

# ─── Supabase Storage ────────────────────────────────────────────────
# URL from: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://<your-project-ref>.supabase.co
# Use the service_role key (server-side only, never expose to client!)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
# Name of the public storage bucket created in Supabase Dashboard
SUPABASE_STORAGE_BUCKET=profilehub-assets
